# Zero-Proxy Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# Dashboard password (REQUIRED for dashboard access)
# Each instance MUST set a unique password
DASHBOARD_PASSWORD=12345

# Optional: require clients to send `Authorization: Bearer <PROXY_KEY>`.
# Recommended for production — prevents unauthorized API access.
PROXY_KEY=

# OpenCode API key (optional)
# If set, upstream identifies this instance by key — use a unique key per instance.
# If not set, upstream rate-limits by IP address (each server = separate identity).
# Unlocks paid + gated free models (glm-4.7-free, kimi-k2.5-free, etc).
OPENCODE_API_KEY=

# Optional pooled upstream keys. Separate with commas or new lines.
# The proxy rotates these keys to reduce pressure on a single identity.
OPENCODE_API_KEYS=

# Rate limit per user per minute (default: 30)
RATE_LIMIT_PER_MIN=30

# Per-user cooldown after a model returns upstream 429 (default: 60000 ms)
MODEL_COOLDOWN_MS=60000

# Global model cooldown after upstream 429 so other requests skip the hot model too
# Default follows MODEL_COOLDOWN_MS when left empty.
GLOBAL_MODEL_COOLDOWN_MS=60000

# By default explicit `model` requests stay on that exact model.
# Set true only if you want fallback to switch models even when client picked one.
ALLOW_EXPLICIT_MODEL_FALLBACK=false

# Burst control before requests hit upstream
UPSTREAM_MAX_CONCURRENCY=4
UPSTREAM_QUEUE_SIZE=100

# Server configuration
PORT=8787
HOST=0.0.0.0

# Cloudflare tunnel URL (auto-set when tunnel is started via dashboard)
TUNNEL_URL=
