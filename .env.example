# Zero-Proxy Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# Dashboard password (REQUIRED for dashboard access)
# Each instance MUST set a unique password
DASHBOARD_PASSWORD=12345

# Optional: require clients to send `Authorization: Bearer <PROXY_KEY>`.
# Recommended for production — prevents unauthorized API access.
PROXY_KEY=

# OpenCode API key (optional)
# If set, upstream identifies this instance by key — use a unique key per instance.
# If not set, upstream rate-limits by IP address (each server = separate identity).
# Unlocks paid + gated free models (glm-4.7-free, kimi-k2.5-free, etc).
OPENCODE_API_KEY=

# Rate limit per user per minute (default: 30)
RATE_LIMIT_PER_MIN=30

# Server configuration
PORT=8787
HOST=0.0.0.0

# Cloudflare tunnel URL (auto-set when tunnel is started via dashboard)
TUNNEL_URL=
