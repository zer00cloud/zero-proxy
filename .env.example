# OpenCode API key unlocks paid + gated free models (glm-4.7-free, kimi-k2.5-free, etc).
# Leave blank to run anonymously — only minimax-m2.5-free, big-pickle, nemotron-3-super-free work.
OPENCODE_API_KEY=

# Optional: require clients to send `Authorization: Bearer <PROXY_KEY>`.
# Leave blank to accept anyone on the network (fine for localhost).
PROXY_KEY=

PORT=8787
HOST=0.0.0.0
